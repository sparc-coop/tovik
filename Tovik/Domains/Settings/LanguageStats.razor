@using Sparc.Blossom.Content

<table>
    <thead>
        <tr>
            <th>
                <h4>Language</h4>
                Dialect
            </th>
            <th>
                Visits
            </th>
        </tr>
        <tr class="search">
            <th colspan="2">
                <input type="search" placeholder="Search languages..." @bind="SearchText" @bind:event="oninput" @bind:after="Search" />
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var language in FilteredLanguages.OrderByDescending(x => Stats.ContainsKey(x) ? Stats[x] : -1).ThenBy(x => x.LanguageDisplayName).ThenBy(x => x.DialectDisplayName))
        {
            <tr>
                <td>
                    <a href="@PreviewLink(language)" class="gotopreview" target="_blank">
                        <h4>@language.LanguageDisplayName</h4>
                        <h5>@language.DialectDisplayName</h5>
                    </a>
                </td>
                <td>
                    @(Stats.ContainsKey(language) ? Stats[language].ToString("N0") : "")
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Stats.Any())
{
    <aside>Nothing to see here yet!</aside>
}


@inject ISparcContent Tovik
@inject TovikDomains TovikDomains
@code {
    [Parameter] public required SparcDomain Domain { get; set; }
    [Parameter] public Page? Page { get; set; }
    Dictionary<Language, int> Stats = [];
    IEnumerable<Language> Languages = [];
    IEnumerable<Language> FilteredLanguages = [];
    string SearchText = "";

    protected override async Task OnParametersSetAsync()
    {
        if (Languages.Count() == 0)
            Languages = await Tovik.GetLanguages();

        FilteredLanguages = Languages;

        if (Page != null)
        {
            Stats = Page.TovikUsage
            .GroupBy(x => Language(x.Key)!)
            .ToDictionary(g => g.Key, g => g.Count()) ?? [];
        }
        else
        {
            var allPages = await TovikDomains.GetPages(Domain.Domain);
            Stats = allPages
                .SelectMany(p => p.TovikUsage)
                .GroupBy(x => Language(x.Key)!)
                .Where(x => x.Key != null)
                .ToDictionary(g => g.Key, g => g.Count()) ?? [];
        }
    }

    void Search()
    {
        if (string.IsNullOrWhiteSpace(SearchText))
        {
            FilteredLanguages = Languages;
        }
        else
        {
            var search = SearchText.Trim().ToLower();
            FilteredLanguages = Languages.Where(l =>
                l.LanguageDisplayName.ToLower().Contains(search) ||
                l.LanguageNativeName.ToLower().Contains(search) ||
                (l.DialectDisplayName != null && l.DialectDisplayName.ToLower().Contains(search)) ||
                (l.DialectNativeName != null && l.DialectNativeName.ToLower().Contains(search)) ||
                l.Id.ToLower().Contains(search));
        }
    }

    string PreviewLink(Language language)
    {
        if (Domain.DateConnected == null)
            return $"/sites/{Domain.Id}/preview?l={language.Id}";

        return $"https://{Domain.Domain}?plang={language.Id}";
    }

    Language? Language(string id) => FilteredLanguages.FirstOrDefault(x => x.Matches(id));

    string FillPercentage(Language language)
    {
        if (Domain == null || Domain.TovikUsage == 0)
            return "0";

        var total = Stats.Values.Sum();
        if (total == 0)
            return "0";

        if (Stats.TryGetValue(language, out var usage))
        {
            var result = (decimal)usage / total * 100;
            return result.ToString("0.##") + "%";
        }

        return "0";
    }
}
